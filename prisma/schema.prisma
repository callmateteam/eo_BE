datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  name               String    @default("") @db.VarChar(30)
  username           String    @unique @db.VarChar(50)
  password           String    @default("") @db.VarChar(255)
  email              String?   @unique @db.VarChar(255)
  profileImage       String?   @map("profile_image") @db.VarChar(500)
  googleId           String?   @unique @map("google_id") @db.VarChar(255)
  googleRefreshToken String?   @map("google_refresh_token") @db.VarChar(500)
  tiktokId           String?   @unique @map("tiktok_id") @db.VarChar(255)
  tiktokAccessToken  String?   @map("tiktok_access_token") @db.VarChar(500)
  instagramId        String?   @unique @map("instagram_id") @db.VarChar(255)
  instagramToken     String?   @map("instagram_token") @db.VarChar(500)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  projects         Project[]
  refreshTokens    RefreshToken[]
  customCharacters CustomCharacter[]
  storyboards      Storyboard[]

  @@map("users")
}

enum CharacterCategory {
  MEME
  ACTION
  CUTE
  BEAUTY
}

model Character {
  id             String            @id @default(uuid()) @db.Uuid
  name           String            @db.VarChar(50)
  nameEn         String            @map("name_en") @db.VarChar(100)
  series         String            @db.VarChar(100)
  category       CharacterCategory
  imageUrl       String            @map("image_url") @db.VarChar(500)
  thumbnailUrl   String            @map("thumbnail_url") @db.VarChar(500)
  description    String            @db.VarChar(500)
  promptFeatures String            @map("prompt_features") @db.VarChar(1000)
  heightCm       Int               @default(170) @map("height_cm")
  bodyBuild      String            @map("body_build") @db.VarChar(100)
  faceFeatures   String            @map("face_features") @db.VarChar(500)
  costumeDesc    String            @map("costume_desc") @db.VarChar(500)
  distinctMarks  String            @map("distinct_marks") @db.VarChar(500)
  veoPrompt      String            @map("veo_prompt") @db.VarChar(2000)
  voiceId        String            @default("alloy") @map("voice_id") @db.VarChar(50)
  voiceStyle     String            @default("") @map("voice_style") @db.VarChar(500)
  bodyType       String            @map("body_type") @db.VarChar(50)
  primaryColor   String            @map("primary_color") @db.VarChar(30)
  sortOrder      Int               @default(0) @map("sort_order")
  isActive       Boolean           @default(true) @map("is_active")
  createdAt      DateTime          @default(now()) @map("created_at")

  projects       Project[]
  storyboards    Storyboard[]

  @@index([category])
  @@index([isActive])
  @@map("characters")
}

enum ProjectStatus {
  CREATED
  SCRIPT_WRITTEN
  VOICE_GENERATED
  VIDEO_GENERATED
  COMPLETED
}

model Project {
  id             String        @id @default(uuid()) @db.Uuid
  title          String        @db.VarChar(100)
  keyword        String        @default("") @db.VarChar(100)
  characterId    String        @map("character_id") @db.Uuid
  status         ProjectStatus @default(CREATED)
  userId         String        @map("user_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  character      Character     @relation(fields: [characterId], references: [id])

  @@index([userId])
  @@index([characterId])
  @@index([keyword])
  @@map("projects")
}

enum CharacterStyle {
  REALISTIC
  ANIME
  CARTOON_3D
  ILLUSTRATION_2D
  CLAY
  WATERCOLOR
}

enum CustomCharacterStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model CustomCharacter {
  id          String                @id @default(uuid()) @db.Uuid
  name        String                @db.VarChar(50)
  description String                @db.VarChar(500)
  style       CharacterStyle
  imageUrl1   String                @map("image_url_1") @db.VarChar(500)
  imageUrl2   String                @map("image_url_2") @db.VarChar(500)
  veoPrompt   String?               @map("veo_prompt") @db.VarChar(2000)
  voiceId     String                @default("alloy") @map("voice_id") @db.VarChar(50)
  voiceStyle  String                @default("") @map("voice_style") @db.VarChar(500)
  status      CustomCharacterStatus @default(PROCESSING)
  errorMsg    String?               @map("error_msg") @db.VarChar(500)
  userId      String                @map("user_id") @db.Uuid
  createdAt   DateTime              @default(now()) @map("created_at")

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyboards Storyboard[]

  @@index([userId])
  @@map("custom_characters")
}

enum StoryboardStatus {
  GENERATING
  READY
  VIDEO_GENERATING
  VIDEO_READY
  FAILED
}

enum SceneVideoStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model Storyboard {
  id                 String           @id @default(uuid()) @db.Uuid
  idea               String           @db.VarChar(2000)
  characterId        String?          @map("character_id") @db.Uuid
  customCharacterId  String?          @map("custom_character_id") @db.Uuid
  status             StoryboardStatus @default(GENERATING)
  errorMsg           String?          @map("error_msg") @db.VarChar(500)
  heroFrameUrl       String?          @map("hero_frame_url") @db.VarChar(500)
  bgmMood            String?          @map("bgm_mood") @db.VarChar(50)
  finalVideoUrl      String?          @map("final_video_url") @db.VarChar(500)
  userId             String           @map("user_id") @db.Uuid
  createdAt          DateTime         @default(now()) @map("created_at")

  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  character          Character?       @relation(fields: [characterId], references: [id])
  customCharacter    CustomCharacter? @relation(fields: [customCharacterId], references: [id])
  scenes             StoryboardScene[]

  @@index([userId])
  @@map("storyboards")
}

enum SceneImageStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
  STALE
}

model StoryboardScene {
  id             String           @id @default(uuid()) @db.Uuid
  storyboardId   String           @map("storyboard_id") @db.Uuid
  sceneOrder     Int              @map("scene_order")
  title          String           @db.VarChar(100)
  content        String           @db.VarChar(2000)
  imagePrompt    String           @map("image_prompt") @db.VarChar(2000)
  imageUrl       String?          @map("image_url") @db.VarChar(500)
  imageStatus    SceneImageStatus @default(PENDING) @map("image_status")
  hasCharacter   Boolean          @default(true) @map("has_character")
  duration       Float            @default(5.0)
  narration      String?          @db.VarChar(1000)
  narrationStyle String           @default("none") @map("narration_style") @db.VarChar(20)
  narrationUrl   String?          @map("narration_url") @db.VarChar(500)
  videoUrl       String?          @map("video_url") @db.VarChar(500)
  videoStatus    SceneVideoStatus @default(PENDING) @map("video_status")
  videoError     String?          @map("video_error") @db.VarChar(500)
  videoStartedAt DateTime?        @map("video_started_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  storyboard     Storyboard       @relation(fields: [storyboardId], references: [id], onDelete: Cascade)

  @@index([storyboardId])
  @@map("storyboard_scenes")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique @db.VarChar(255)
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}
