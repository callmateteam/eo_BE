      }
    ],
    "PreCommit": [
      {
        "command": "cd /c/Users/somem/Desktop/해커톤/eo_BE && source .venv/Scripts/activate && python -m ruff check . && python -m pytest -q 2>/dev/null"
      }
    ]
  }
